views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder.startsWith("content")
        - type == "THOUGHT"
    groupBy:
      property: parent
      direction: ASC
    order:
      - file.name
      - type
      - file.folder
      - level
      - neo4j
      - verified
      - alias
    sort:
      - property: level
        direction: ASC
