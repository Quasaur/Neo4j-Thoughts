views:
  - type: table
    name: Table
    filters:
      and:
        - file.path.startsWith("content")
        - type == "PASSAGE"
    groupBy:
      property: parent
      direction: ASC
    order:
      - file.name
      - name
      - level
      - neo4j
      - verified
      - alias
    sort:
      - property: verified
        direction: ASC
      - property: level
        direction: ASC
    columnSize:
      note.level: 103
